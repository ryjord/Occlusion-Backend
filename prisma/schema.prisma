generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// TECHNICIAN
model Technician {
  id                   String   @id @default(uuid())
  employeeId           String   @unique
  fullName             String
  role                 String   // "Admin" or "Technician"
  passwordHash         String   // Storing Argon2 hash
  registeredHardwareId String   // Device binding for security
  createdAt            DateTime @default(now())

  auditLogs   AuditTrail[]
}

// FAULT_LOG
model FaultLog {
  id              String   @id @default(uuid())
  markerId        String   // AR Anchor Reference
  status          String   @default("Open") // Open, In Progress, Resolved
  severity        String   @default("Warning") // Critical, Warning, Checked
  annotationNotes String?  @db.Text
  spatialX        Float    // 3D Coordinate
  spatialY        Float    // 3D Coordinate
  spatialZ        Float    // 3D Coordinate
  createdAt       DateTime @default(now())
  resolvedAt      DateTime?
}

// TOOL
model Tool {
  id              String   @id @default(uuid())
  toolName        String
  category        String
  lastKnownX      Float    // Telemetry Data
  lastKnownY      Float
  lastKnownZ      Float
  lastTrackedAt   DateTime @updatedAt
}

// AUDIT_TRAIL
model AuditTrail {
  id               String   @id @default(uuid())
  targetTable      String
  targetRecordId   String
  actionType       String   // "INSERT", "UPDATE", "DELETE"
  actionTimestamp  DateTime @default(now())

  // PostgreSQL specific JSONB for storing the exact data changes
  previousState    Json?
  newState         Json?

  changedById      String
  changedBy        Technician @relation(fields: [changedById], references: [id])
}
